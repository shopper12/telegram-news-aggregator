# Telegram user API credentials from https://my.telegram.org
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_NAME=telegram_news_session
TELEGRAM_PHONE=

# Optional: use this for cloud/GitHub Actions runs instead of a .session file
TELEGRAM_STRING_SESSION=

# Optional: send summary to Telegram via bot
# Single recipient compatibility
TELEGRAM_TARGET_CHAT_ID=
# Multiple recipients, comma-separated. Example: 111111111,222222222,333333333
TELEGRAM_TARGET_CHAT_IDS=
TELEGRAM_BOT_TOKEN=

# Optional: Gemini classification / title ordering
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# App
DATABASE_URL=sqlite:///data/news.db
CHANNEL_CONFIG=config/channels.yaml
TIMEZONE=Asia/Seoul
