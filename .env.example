# Telegram user API credentials from https://my.telegram.org
# Required only for collecting source Telegram channels. This is not a bot token.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_NAME=telegram_news_session
TELEGRAM_PHONE=

# Optional: use this for cloud/GitHub Actions runs instead of a .session file
TELEGRAM_STRING_SESSION=

# Bot/API server
RENDER_API_BASE_URL=https://telegram-news-bot-api.onrender.com
NEWS_BOT_API_KEY=
LATEST_REPORT_URL=https://raw.githubusercontent.com/shopper12/telegram-news-aggregator/main/reports/latest_report.json

# ChatGPT briefing picks bridge for `봇 추천`
CHAT_PICKS_API_KEY=
CHAT_PICKS_POST_URL=https://telegram-news-bot-api.onrender.com/api/recommendations
CHAT_PICKS_SOURCE_URL=
STOCK_SCANNER_RECOMMENDATIONS_URL=
CHAT_PICKS_JSON=
CHAT_PICKS_PATH=/tmp/chat_picks.json

# Notification target for `run --send`: kakao, discord, or both
NOTIFIER=discord
DISCORD_WEBHOOK_URL=
DISCORD_WEBHOOK_USERNAME=뉴스봇

# KakaoTalk send target: KakaoTalk memo / "나에게 보내기"
# Deprecated for open-chat bot mode. Keep empty unless you still want memo sends.
KAKAO_REST_API_KEY=
KAKAO_REFRESH_TOKEN=
KAKAO_CLIENT_SECRET=
KAKAO_WEB_URL=https://telegram-news-bot-api.onrender.com

# Deprecated: old Telegram bot send settings. Keep empty unless you restore Telegram bot sending manually.
TELEGRAM_TARGET_CHAT_ID=
TELEGRAM_TARGET_CHAT_IDS=
TELEGRAM_BOT_TOKEN=

# Optional: Gemini classification / report synthesis
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# App
DATABASE_URL=sqlite:///data/news.db
CHANNEL_CONFIG=config/channels.yaml
TIMEZONE=Asia/Seoul
